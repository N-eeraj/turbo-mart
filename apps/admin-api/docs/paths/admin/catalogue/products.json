                },
                "SubcategoryNotFound": {
                  "summary": "Subcategory not found",
                  "value": {
                    "success": false,
                    "message": "Subcategory not found"
                  }
                }
              }
            }
          }
        },
        "409": {
          "description": "Conflict error.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "example": false,
                    "description": "Indicates the request failed."
                  },
                  "message": {
                    "type": "string",
                    "example": "Product with same name exists in this subcategory for this brand"
                  }
                }
              }
            }
          }
        },
        "422": {
          "description": "Validation error (if request body is missing required fields, or has invalid field values).",
          "content": {
            "application/json": {
              "example": {
                "success": false,
                "message": "Validation Error",
                "errors": {
                  "subcategory": [
                    "Please select a subcategory"
                  ],
                  "brand": [
                    "Please select a brand"
                  ],
                  "name": [
                    "Please enter a product name"
                  ]
                }
              }
            }
          }
        },
        "500": {
          "$ref": "#/components/responses/InternalServerError"
        }
      }
    }
  }
}
