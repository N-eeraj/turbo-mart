{
  "/api/admin/catalogue/products": {
    "post": {
      "tags": ["Product Management"],
      "summary": "Create Product",
      "description": "Create new product.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ProductCreationSchema"
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Create product.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "description": "Boolean indicating whether the request was successful."
                  },
                  "data": {
                    "$ref": "#/components/schemas/ProductBasicDetailsSchema"
                  },
                  "message": {
                    "type": "string",
                    "example": "Created Product"
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Invalid data error.",
          "content": {
            "application/json": {
              "examples": {
                "InvalidIds": {
                  "summary": "Invalid Id",
                  "value": {
                    "success": false,
                    "message": "Invalid ids",
                    "errors": {
                      "brand": "string",
                      "subcategory": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "401": {
          "$ref": "#/components/responses/UnauthenticatedUser"
        },
        "403": {
          "$ref": "#/components/responses/UnauthorizedUser"
        },
        "404": {
          "description": "Not found error.",
          "content": {
            "application/json": {
              "examples": {
                "BrandNotFound": {
                  "summary": "Brand not found",
                  "value": {
                    "success": false,
                    "message": "Brand not found"
                  }
                },
                "SubcategoryNotFound": {
                  "summary": "Subcategory not found",
                  "value": {
                    "success": false,
                    "message": "Subcategory not found"
                  }
                }
              }
            }
          }
        },
        "409": {
          "description": "Conflict error.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "example": false,
                    "description": "Indicates the request failed."
                  },
                  "message": {
                    "type": "string",
                    "example": "Product with same name exists in this subcategory for this brand"
                  }
                }
              }
            }
          }
        },
        "422": {
          "description": "Validation error (if request body is missing required fields, or has invalid field values).",
          "content": {
            "application/json": {
              "example": {
                "success": false,
                "message": "Validation Error",
                "errors": {
                  "subcategory": [
                    "Please select a subcategory"
                  ],
                  "brand": [
                    "Please select a brand"
                  ],
                  "name": [
                    "Please enter a product name"
                  ]
                }
              }
            }
          }
        },
        "500": {
          "$ref": "#/components/responses/InternalServerError"
        }
      }
    }
  },
  "/api/admin/catalogue/products/{productId}": {
    "get": {
      "tags": ["Product Management"],
      "summary": "Fetch Product",
      "description": "Fetch product details.",
      "parameters": [
        {
          "name": "productId",
          "in": "path",
          "required": true,
          "description": "ID of the product.",
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "fields",
          "in": "query",
          "description": "Fields to be included in the response",
          "schema": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "basic",
                "attributes",
                "variants"
              ]
            }
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Fetched product.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "description": "Boolean indicating whether the request was successful."
                  },
                  "data": {
                    "$ref": "#/components/schemas/ProductSchema"
                  },
                  "message": {
                    "type": "string",
                    "example": "Fetched Product"
                  }
                }
              }
            }
          }
        },
        "400": {
          "$ref": "#/components/responses/InvalidProductId"
        },
        "401": {
          "$ref": "#/components/responses/UnauthenticatedUser"
        },
        "403": {
          "$ref": "#/components/responses/UnauthorizedUser"
        },
        "404": {
          "description": "Product not found.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "example": false,
                    "description": "Indicates the request failed."
                  },
                  "message": {
                    "type": "string",
                    "example": "Product not found",
                    "description": "Error message: Couldn't find the product."
                  }
                }
              }
            }
          }
        },
        "500": {
          "$ref": "#/components/responses/InternalServerError"
        }
      }
    },
    "patch": {
      "tags": ["Product Management"],
      "summary": "Fetch Product",
      "description": "Fetch product details.",
