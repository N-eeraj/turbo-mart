                  "data": {
                    "$ref": "#/components/schemas/ProductBasicDetailsSchema"
                  },
                  "message": {
                    "type": "string",
                    "example": "Updated Product Details"
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Invalid data error.",
          "content": {
            "application/json": {
              "examples": {
                "InvalidIds": {
                  "summary": "Invalid Id",
                  "value": {
                    "success": false,
                    "message": "Invalid ids",
                    "errors": {
                      "id": "string",
